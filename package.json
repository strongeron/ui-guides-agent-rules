{
  "name": "ui-guides",
  "private": true,
  "version": "1.0.0",
  "description": "UI Guides & Agent Rules — 300+ web UI principles with good/bad examples and copy-paste MUST/SHOULD/NEVER rules for coding agents.",
  "homepage": "https://ui-guides-agent-rules.netlify.app",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:llms": "npx tsx scripts/generate-llms.ts",
    "prebuild": "npm run generate:llms",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:principle": "playwright test tests/e2e/principle-visual.spec.ts",
    "test:e2e:visual": "playwright test tests/e2e/dark-mode-regression.spec.ts",
    "test:e2e:visual:all": "VISUAL_TEST_ALL=true playwright test tests/e2e/dark-mode-regression.spec.ts",
    "test:e2e:visual:update": "playwright test tests/e2e/dark-mode-regression.spec.ts --update-snapshots",
    "validate": "npx tsx scripts/validate-principles.ts",
    "check:sources": "npx tsx scripts/check-source-freshness.ts",
    "sources:build": "npx tsx scripts/build-source-rules.ts",
    "sources:catalog": "npx tsx scripts/check-source-catalog.ts",
    "sources:discover": "npx tsx scripts/discover-sources.ts",
    "check:secrets": "npx tsx scripts/check-secrets.ts",
    "hooks:install": "git config core.hooksPath .githooks && echo 'pre-commit secret gate enabled'",
    "validate:links": "npx tsx scripts/check-source-links.ts",
    "validate:rules": "npx tsx scripts/validate-agent-rules.ts",
    "validate:report": "npx tsx scripts/generate-validation-report.ts",
    "validate:visual": "npx tsx scripts/visual-validation.ts",
    "validate:screenshots": "npx tsx scripts/capture-screenshots.ts",
    "validate:dark-mode": "npx tsx scripts/validate-dark-mode-screenshots.ts",
    "validate:dark-mode:all": "npx tsx scripts/validate-dark-mode-screenshots.ts --all",
    "validate:init": "npx tsx scripts/visual-validation.ts init",
    "validate:comprehensive": "npx tsx scripts/validate-all-comprehensive.ts",
    "validate:all": "npm run validate:comprehensive"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^3.1.1",
    "@hugeicons/react": "^1.1.4",
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.1.18",
    "agentation": "^1.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "codehike": "^1.0.7",
    "lucide-react": "^0.344.0",
    "motion": "^12.28.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.0.17",
    "eslint": "^9.9.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "jsdom": "^27.4.0",
    "shadcn": "^3.6.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vitest": "^4.0.17"
  },
  "author": "Gleb Stroganov <strongeron@evilmartians.com> (https://glebstroganov.com)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/strongeron/ui-guides-agent-rules.git"
  }
}
