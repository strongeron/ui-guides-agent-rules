        {
          "source": "emilkowalski",
          "text": "Constant motion (marquee, progress) → `linear`",
          "suggestedId": "emilkowalski-constant-motion-marquee-progress",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.25
        },
        {
          "source": "emilkowalski",
          "text": "3D: `rotateX/Y` + `transform-style: preserve-3d` for depth/orbit/flip without JS.",
          "suggestedId": "emilkowalski-3d-for-depth-orbit-flip-without",
          "category": "forms",
          "tags": [
            "motion",
            "forms"
          ],
          "bestMatch": 0.25
        },
        {
          "source": "emilkowalski",
          "text": "Friction over hard stops — allow over-drag with rising resistance rather than an invisible wall.",
          "suggestedId": "emilkowalski-friction-over-hard-stops-allow-over",
          "category": "interactions",
          "tags": [
            "motion",
            "interactions"
          ],
          "bestMatch": 0.25
        },
        {
          "source": "emilkowalski",
          "text": "Origin & physical correctness. Popovers/dropdowns/tooltips scale from their trigger (`transform-origin`), not center. Never animate from `scale(0)` — start from `scale(0.9–0.97)` + opacity (Modals are exempt — they stay centered.)",
          "suggestedId": "emilkowalski-origin-physical-correctness-popovers-dropdowns-tooltips",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.29
        },
        {
          "source": "emilkowalski",
          "text": "Framer Motion `x`/`y`/`scale` props on motion that runs while the page is busy",
          "suggestedId": "emilkowalski-framer-motion-props-on-motion-that",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.29
        },
        {
          "source": "emilkowalski",
          "text": "Block — any feel-breaking regression, animation on a keyboard/high-frequency action, `scale(0)`/`ease-in` on UI, or a non-GPU animation with an easy GPU fix.",
          "suggestedId": "emilkowalski-block-any-feel-breaking-regression-animation",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.29
        },
        {
          "source": "emilkowalski",
          "text": "Move it to the GPU — layout props → `transform`/`opacity`; shorthand → full `transform` string; WAAPI for programmatic CSS.",
          "suggestedId": "emilkowalski-move-it-to-the-gpu-layout",
          "category": "forms",
          "tags": [
            "motion",
            "forms"
          ],
          "bestMatch": 0.3
        },
        {
          "source": "emilkowalski",
          "text": "Polish — blur to mask crossfades, stagger for groups, `@starting-style` for entry, spring for \"alive\" elements.",
          "suggestedId": "emilkowalski-polish-blur-to-mask-crossfades-stagger",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.3
        },
        {
          "source": "emilkowalski",
          "text": "`transition: all` (unbounded property animation)",
          "suggestedId": "emilkowalski-unbounded-property-animation",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.33
        },
        {
          "source": "emilkowalski",
          "text": "Missing `prefers-reduced-motion` handling on movement",
          "suggestedId": "emilkowalski-missing-handling-on-movement",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.33
        },
        {
          "source": "emilkowalski",
          "text": "Fix the origin/physicality — correct `transform-origin`; replace `scale(0)` with `scale(0.95)`+opacity.",
          "suggestedId": "emilkowalski-fix-the-origin-physicality-correct-replace",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.33
        },
        {
          "source": "emilkowalski",
          "text": "Missed simplifications — animations that should be removed or drastically reduced.",
          "suggestedId": "emilkowalski-missed-simplifications-animations-that-should-be",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.33
        },
        {
          "source": "emilkowalski",
          "text": "Accessibility — reduced-motion and pointer/hover gating.",
          "suggestedId": "emilkowalski-accessibility-reduced-motion-and-pointer-hover",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.33
        },
        {
          "source": "emilkowalski",
          "text": "Entering or exiting → `ease-out` (starts fast, feels responsive)",
          "suggestedId": "emilkowalski-entering-or-exiting-starts-fast-feels",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.33
        },
        {
          "source": "emilkowalski",
          "text": "Moving / morphing on screen → `ease-in-out`",
          "suggestedId": "emilkowalski-moving-morphing-on-screen",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.33
        },
        {
          "source": "emilkowalski",
          "text": "Origin-aware popovers. Scale from the trigger, not center:",
          "suggestedId": "emilkowalski-origin-aware-popovers-scale-from-the",
          "category": "design",
          "tags": [
            "motion",
            "design"
          ],
          "bestMatch": 0.33
        },
        {
          "source": "emilkowalski",
          "text": "CSS animations beat JS under load — they run off the main thread; rAF-based animations stutter while the browser loads/scripts/paints. Use CSS for predetermined motion, JS for dynamic/interruptible.",
          "suggestedId": "emilkowalski-css-animations-beat-js-under-load",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.33
        },
        {
          "source": "emilkowalski",
          "text": "Prefer CSS transitions/`@starting-style`/WAAPI for predetermined motion; JS/springs for dynamic, interruptible, gesture-driven motion.",
          "suggestedId": "emilkowalski-prefer-css-transitions-waapi-for-predetermined",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.36
        },
        {
          "source": "emilkowalski",
          "text": "Sub-300ms UI. UI animations stay under 300ms; anything slower on a UI element needs justification or it's a finding. Per-element budgets live in STANDARDS.md.",
          "suggestedId": "emilkowalski-sub-300ms-ui-ui-animations-stay",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.4
        },
        {
          "source": "emilkowalski",
          "text": "`scale(0)` or pure-fade entrances with no initial transform",
          "suggestedId": "emilkowalski-or-pure-fade-entrances-with-no",
          "category": "forms",
          "tags": [
            "motion",
            "forms"
          ],
          "bestMatch": 0.4
        },
        {
          "source": "emilkowalski",
          "text": "Responsive easing. Entering/exiting elements use `ease-out` or a strong custom curve. `ease-in` on UI is a block — it delays the moment the user watches most. Built-in CSS easings are too weak; expect custom cubic-beziers.",
          "suggestedId": "emilkowalski-responsive-easing-entering-exiting-elements-use",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.41
        },
        {
          "source": "emilkowalski",
          "text": "Cohesion. Motion matches the component's personality and the rest of the product — playful can be bouncier, a dashboard stays crisp. Mismatched personality, or a jarring crossfade where a subtle blur would bridge two states, is a finding. When unsure whether motion feels right, the strongest move is often to delete it.",
          "suggestedId": "emilkowalski-cohesion-motion-matches-the-component-s",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.41
        },
        {
          "source": "emilkowalski",
          "text": "Only animate `transform` and `opacity` — they skip layout/paint and run on the GPU. `padding`/`margin`/`height`/`width`/`top`/`left` trigger all three rendering steps.",
          "suggestedId": "emilkowalski-only-animate-and-they-skip-layout",
          "category": "performance",
          "tags": [
            "motion",
            "performance"
          ],
          "bestMatch": 0.42
        },
        {
          "source": "emilkowalski",
          "text": "Delete the animation (high-frequency / no purpose / keyboard-triggered).",
          "suggestedId": "emilkowalski-delete-the-animation-high-frequency-no",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.43
        },
        {
          "source": "emilkowalski",
          "text": "Asymmetric timing — slow the deliberate phase, snap the response.",
          "suggestedId": "emilkowalski-asymmetric-timing-slow-the-deliberate-phase",
          "category": "design",
          "tags": [
            "motion",
            "design"
          ],
          "bestMatch": 0.43
        },
        {
          "source": "emilkowalski",
          "text": "Accessibility & cohesion — add reduced-motion + hover gating; tune to match the component's personality.",
          "suggestedId": "emilkowalski-accessibility-cohesion-add-reduced-motion-hover",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.45
        }
      ]
