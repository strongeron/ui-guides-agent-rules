    {
      "source": "emilkowalski",
      "name": "Emil Kowalski",
      "mode": "github",
      "status": "checked",
      "upstreamRules": 43,
      "ourRules": 3,
      "newRules": [
        {
          "source": "emilkowalski",
          "text": "Cohesion. Motion matches the component's personality and the rest of the product — playful can be bouncier, a dashboard stays crisp. Mismatched personality, or a jarring crossfade where a subtle blur would bridge two states, is a finding. When unsure whether motion feels right, the strongest move is often to delete it.",
          "suggestedId": "emilkowalski-cohesion-motion-matches-the-component-s",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.06
        },
        {
          "source": "emilkowalski",
          "text": "Responsive easing. Entering/exiting elements use `ease-out` or a strong custom curve. `ease-in` on UI is a block — it delays the moment the user watches most. Built-in CSS easings are too weak; expect custom cubic-beziers.",
          "suggestedId": "emilkowalski-responsive-easing-entering-exiting-elements-use",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.09
        },
        {
          "source": "emilkowalski",
          "text": "Interruptibility & timing — keyframes where transitions/springs belong; symmetric timing that should be asymmetric.",
          "suggestedId": "emilkowalski-interruptibility-timing-keyframes-where-transitions-springs",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.11
        },
        {
          "source": "emilkowalski",
          "text": "Justified motion. Every animation must answer \"why does this animate?\" — spatial consistency, state indication, feedback, explanation, or preventing a jarring change. \"It looks cool\" on a frequently-seen element is a block.",
          "suggestedId": "emilkowalski-justified-motion-every-animation-must-answer",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.13
        },
        {
          "source": "emilkowalski",
          "text": "Sub-300ms UI. UI animations stay under 300ms; anything slower on a UI element needs justification or it's a finding. Per-element budgets live in STANDARDS.md.",
          "suggestedId": "emilkowalski-sub-300ms-ui-ui-animations-stay",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.13
        },
        {
          "source": "emilkowalski",
          "text": "Fix the easing — swap `ease-in`→`ease-out`/custom curve; use a strong cubic-bezier.",
          "suggestedId": "emilkowalski-fix-the-easing-swap-custom-curve",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.13
        },
        {
          "source": "emilkowalski",
          "text": "Origin, physicality & cohesion — wrong origin, mismatched personality, jarring crossfades.",
          "suggestedId": "emilkowalski-origin-physicality-cohesion-wrong-origin-mismatched",
          "category": "aesthetics",
          "tags": [
            "motion",
            "aesthetics"
          ],
          "bestMatch": 0.13
        },
        {
          "source": "emilkowalski",
          "text": "When unsure whether motion feels right, recommend reviewing it in slow motion / frame-by-frame and with fresh eyes the next day rather than guessing.",
          "suggestedId": "emilkowalski-when-unsure-whether-motion-feels-right",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.13
        },
        {
          "source": "emilkowalski",
          "text": "Keyframes on toasts, toggles, or anything added/triggered rapidly",
