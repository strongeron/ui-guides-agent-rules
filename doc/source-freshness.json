        },
        {
          "source": "emilkowalski",
          "text": "Real devices for gestures (drawers, swipe) — connect a phone, hit the dev server by IP, use Safari remote devtools.",
          "suggestedId": "emilkowalski-real-devices-for-gestures-drawers-swipe",
          "category": "design",
          "tags": [
            "motion",
            "design"
          ],
          "bestMatch": 0.15
        },
        {
          "source": "emilkowalski",
          "text": "Justified motion. Every animation must answer \"why does this animate?\" — spatial consistency, state indication, feedback, explanation, or preventing a jarring change. \"It looks cool\" on a frequently-seen element is a block.",
          "suggestedId": "emilkowalski-justified-motion-every-animation-must-answer",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.17
        },
        {
          "source": "emilkowalski",
          "text": "Approve — no feel-breaking regressions, no obvious motion that should be deleted, durations and easing within bounds, interruptibility handled where needed, reduced-motion respected.",
          "suggestedId": "emilkowalski-approve-no-feel-breaking-regressions-no",
          "category": "animations",
          "tags": [
            "motion",
            "animations"
          ],
          "bestMatch": 0.18
        },
        {
          "source": "emilkowalski",
          "text": "Frame-by-frame: Chrome DevTools Animations panel reveals timing drift between coordinated properties.",
