# Copy to `.env` (gitignored) and fill in. Nothing here is required to run the app —
# these only affect the source-sync scripts.

# Optional. Lifts the GitHub API rate limit (60 -> 5000 req/hr) for `npm run sources:discover`,
# which walks catalogued skill repos to find skills not yet wired into src/data/sources.ts.
# A classic (read-only, no scopes) token is enough. NEVER commit the real value — `.env` is
# gitignored and `npm run check:secrets` will fail the build if a token is committed.
GITHUB_TOKEN=
